AUTH_ADMIN_TOKEN_TTL_MINUTES=480
AUTH_WX_TOKEN_TTL_MINUTES=43200
CORS_ALLOWED_ORIGIN_PATTERNS=http://127.0.0.1:*,http://localhost:*
PAYMENT_CALLBACK_SECRET=change-this-payment-callback-secret

WX_MINI_PROGRAM_SECRET=
WX_DEV_LOGIN_ENABLED=true
