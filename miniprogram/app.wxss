page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 6%, rgba(184, 148, 92, 0.12), transparent 38%),
    radial-gradient(circle at 92% 88%, rgba(28, 38, 50, 0.06), transparent 32%),
    linear-gradient(180deg, #f5f1e9 0%, #ece6da 100%);
  color: #1c2530;
  font-family: "PingFang SC", "Microsoft YaHei", "HarmonyOS Sans SC", sans-serif;
  -webkit-font-smoothing: antialiased;
  letter-spacing: 0.5rpx;
}

.container {
  padding: 32rpx 28rpx 60rpx;
}

.card {
  background: linear-gradient(180deg, rgba(253, 250, 244, 0.98), rgba(247, 242, 233, 0.96));
  border: 1rpx solid rgba(28, 38, 50, 0.08);
  border-radius: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 29, 42, 0.06);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 22rpx;
  padding: 0 4rpx;
}

.section-title {
  position: relative;
  font-size: 34rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
  padding-left: 22rpx;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 12rpx;
  bottom: 10rpx;
  width: 4rpx;
  border-radius: 2rpx;
  background: linear-gradient(180deg, #c8a570, #8a6a3e);
}

.section-subtitle {
  margin-top: 8rpx;
  margin-left: 22rpx;
  font-size: 22rpx;
  color: #7a8290;
  letter-spacing: 0.6rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  height: 44rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

.pill-brand {
  color: #8a6a3e;
  background: rgba(184, 148, 92, 0.14);
  border: 1rpx solid rgba(184, 148, 92, 0.22);
}

.pill-success {
  color: #2f7d55;
  background: rgba(47, 125, 85, 0.10);
  border: 1rpx solid rgba(47, 125, 85, 0.18);
}

.pill-warning {
  color: #b07a2c;
  background: rgba(176, 122, 44, 0.10);
  border: 1rpx solid rgba(176, 122, 44, 0.20);
}

.pill-danger {
  color: #a05a56;
  background: rgba(160, 90, 86, 0.10);
  border: 1rpx solid rgba(160, 90, 86, 0.20);
}

.primary-btn,
.ghost-btn {
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  transition: all 0.25s ease;
}

.primary-btn {
  color: #f4e8d2;
  background: linear-gradient(135deg, #1d3146 0%, #0f1d2a 100%);
  box-shadow: 0 14rpx 28rpx rgba(15, 29, 42, 0.22);
  border: 1rpx solid rgba(216, 184, 136, 0.12);
}

.primary-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 16rpx rgba(15, 29, 42, 0.18);
}

.ghost-btn {
  color: #14202c;
  background: rgba(255, 252, 247, 0.88);
  border: 1rpx solid rgba(28, 38, 50, 0.14);
}

.ghost-btn:active {
  background: rgba(255, 252, 247, 0.96);
  border-color: rgba(184, 148, 92, 0.42);
}

.muted {
  color: #7a8290;
}

.price {
  color: #8a6a3e;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}
