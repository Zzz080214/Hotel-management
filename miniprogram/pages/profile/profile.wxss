.profile-card {
  position: relative;
  padding: 44rpx 30rpx;
  text-align: center;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 0%, rgba(216, 184, 136, 0.20), transparent 56%),
    linear-gradient(180deg, #0d1822 0%, #142434 100%);
}

.profile-card::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 30rpx;
  transform: translateX(-50%);
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(216, 184, 136, 0.95), transparent);
}

.login-card {
  padding: 32rpx 30rpx;
  margin-bottom: 22rpx;
}

.login-status {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(28, 38, 50, 0.06);
  display: flex;
  align-items: center;
  gap: 18rpx;
  text-align: left;
}

.login-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1d3146 0%, #0f1d2a 100%);
  color: #f4e8d2;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  border: 1rpx solid rgba(216, 184, 136, 0.24);
}

.login-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0.6rpx;
}

.login-meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #7a8290;
  letter-spacing: 0.4rpx;
}

.avatar {
  width: 124rpx;
  height: 124rpx;
  margin: 0 auto;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8cda0 0%, #b8945c 100%);
  color: #14202c;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  font-family: "Songti SC", "STSong", serif;
  box-shadow: 0 16rpx 32rpx rgba(120, 90, 50, 0.38), inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
}

.profile-name {
  margin-top: 22rpx;
  font-size: 36rpx;
  font-weight: 500;
  color: #f5e8cc;
  letter-spacing: 4rpx;
  font-family: "Songti SC", "STSong", serif;
}

.profile-desc {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.75;
  color: rgba(231, 234, 238, 0.74);
  letter-spacing: 0.4rpx;
}

.source-line {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: rgba(216, 184, 136, 0.72);
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
}

.profile-card .source-line {
  color: rgba(216, 184, 136, 0.72);
}

.login-btn {
  margin-top: 26rpx;
}

.profile-card .login-btn {
  background: linear-gradient(135deg, #e8cda0, #b8945c);
  color: #14202c;
  border: 0;
  box-shadow: 0 14rpx 28rpx rgba(120, 90, 50, 0.36);
}

.logout-btn {
  margin-top: 22rpx;
}

.profile-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 30rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid rgba(216, 184, 136, 0.16);
}

.stat-box {
  flex: 1;
  padding: 4rpx 0;
  background: transparent;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #f5e8cc;
  letter-spacing: 0;
  font-variant-numeric: tabular-nums;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(216, 184, 136, 0.72);
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
}

.section {
  margin-top: 32rpx;
}

.menu-card {
  padding: 28rpx 26rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: transform 0.2s ease;
}

.menu-card:active {
  transform: translateY(2rpx);
}

.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0.8rpx;
}

.menu-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7a8290;
  letter-spacing: 0.4rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #b8945c;
  font-weight: 300;
}

.feature-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 29, 42, 0.50);
  backdrop-filter: blur(6rpx);
}

.feature-panel {
  width: 100%;
  max-height: 82vh;
  padding: 36rpx 28rpx 48rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: linear-gradient(180deg, #fdfaf4 0%, #f7f2e9 100%);
  box-sizing: border-box;
  overflow-y: auto;
  border-top: 1rpx solid rgba(216, 184, 136, 0.30);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 26rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(28, 38, 50, 0.08);
}

.panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
}

.panel-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7a8290;
  letter-spacing: 0.4rpx;
}

.panel-close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(28, 38, 50, 0.06);
  color: #14202c;
  font-size: 36rpx;
  line-height: 1;
}

.guest-form {
  display: grid;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.form-input {
  height: 84rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid rgba(28, 38, 50, 0.10);
  box-sizing: border-box;
  font-size: 26rpx;
  color: #14202c;
}

.form-submit {
  height: 84rpx;
}

.guest-item,
.coupon-item,
.service-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid rgba(28, 38, 50, 0.08);
  box-shadow: 0 8rpx 18rpx rgba(15, 29, 42, 0.04);
}

.guest-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.guest-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0.4rpx;
}

.guest-line {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #7a8290;
  letter-spacing: 0.4rpx;
}

.guest-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.guest-action {
  min-width: 96rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(184, 148, 92, 0.10);
  color: #8a6a3e;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.6rpx;
  border: 1rpx solid rgba(184, 148, 92, 0.20);
}

.guest-action.danger {
  color: #a05a56;
  background: rgba(160, 90, 86, 0.08);
  border-color: rgba(160, 90, 86, 0.20);
}

.panel-empty {
  padding: 40rpx 0;
  text-align: center;
  color: #7a8290;
  font-size: 23rpx;
  letter-spacing: 0.4rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 22rpx;
}

.coupon-value {
  width: 116rpx;
  min-height: 116rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, #1d3146 0%, #0f1d2a 100%);
  color: #f4e8d2;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0;
  border: 1rpx solid rgba(216, 184, 136, 0.24);
  font-variant-numeric: tabular-nums;
}

.coupon-main {
  flex: 1;
  min-width: 0;
}

.coupon-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0.6rpx;
}

.coupon-desc,
.coupon-date {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a8290;
  letter-spacing: 0.4rpx;
}

.coupon-action {
  width: 104rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, #e8cda0, #b8945c);
  color: #14202c;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

.coupon-action-disabled {
  color: #7a8290;
  background: rgba(28, 38, 50, 0.08);
}

.password-card,
.checkout-item {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid rgba(28, 38, 50, 0.08);
}

.password-card {
  text-align: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(216, 184, 136, 0.16), transparent 60%),
    linear-gradient(180deg, #fdfaf4 0%, #fff 100%);
  border-color: rgba(184, 148, 92, 0.24);
}

.password-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 0;
  color: #7a8290;
  font-size: 23rpx;
  border-bottom: 1rpx solid rgba(28, 38, 50, 0.06);
  letter-spacing: 0.4rpx;
}

.password-meta text:last-child {
  max-width: 430rpx;
  color: #14202c;
  font-weight: 600;
  text-align: right;
}

.password-room {
  margin-top: 28rpx;
  color: #8a6a3e;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.password-code {
  margin-top: 18rpx;
  font-size: 78rpx;
  line-height: 1.1;
  font-weight: 600;
  letter-spacing: 12rpx;
  color: #14202c;
  font-variant-numeric: tabular-nums;
}

.password-expire {
  margin-top: 16rpx;
  color: #8a6a3e;
  font-size: 22rpx;
  letter-spacing: 0.4rpx;
}

.checkout-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.checkout-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0.6rpx;
}

.checkout-line {
  margin-top: 10rpx;
  color: #7a8290;
  font-size: 22rpx;
  letter-spacing: 0.4rpx;
}

.checkout-btn {
  width: 116rpx;
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #f4e8d2;
  background: linear-gradient(135deg, #1d3146, #0f1d2a);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1.6rpx;
  border: 1rpx solid rgba(216, 184, 136, 0.18);
}

.service-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(28, 38, 50, 0.06);
}

.service-row:last-child {
  border-bottom: 0;
}

.service-label {
  color: #7a8290;
  font-size: 23rpx;
  letter-spacing: 0.4rpx;
}

.service-value {
  max-width: 430rpx;
  text-align: right;
  color: #14202c;
  font-size: 25rpx;
  font-weight: 600;
  word-break: break-all;
  letter-spacing: 0.4rpx;
}

.service-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.password-actions {
  grid-template-columns: 1fr;
}

.service-btn,
.native-contact {
  height: 84rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.native-contact {
  width: 100%;
  margin: 18rpx 0 0;
  padding: 0;
  border: 1rpx solid rgba(28, 38, 50, 0.12);
  line-height: 84rpx;
  background: rgba(255, 252, 247, 0.92);
  color: #14202c;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.native-contact::after {
  border: 0;
}
