.profile-card {
  padding: 30rpx;
  text-align: center;
}

.login-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.login-status {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  text-align: left;
}

.login-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #111 0%, #444 52%, #fff 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.login-name {
  font-size: 28rpx;
  font-weight: 700;
}

.login-meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #7c6651;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0c996, #b96b2c);
  color: #4b250d;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-name {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7c6651;
}

.source-line {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9b5b28;
}

.login-btn {
  margin-top: 24rpx;
}

.logout-btn {
  margin-top: 22rpx;
}

.profile-stats {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.stat-box {
  flex: 1;
  padding: 20rpx 12rpx;
  border-radius: 22rpx;
  background: rgba(185, 107, 44, 0.08);
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #7f4318;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7c6651;
}

.section {
  margin-top: 28rpx;
}

.menu-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 700;
}

.menu-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7c6651;
}

.menu-arrow {
  font-size: 42rpx;
  color: #b18b67;
}

.feature-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(42, 28, 15, 0.42);
}

.feature-panel {
  width: 100%;
  max-height: 82vh;
  padding: 30rpx 24rpx 42rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #fffaf1;
  box-sizing: border-box;
  overflow-y: auto;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
}

.panel-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7c6651;
}

.panel-close {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(127, 67, 24, 0.08);
  color: #7f4318;
  font-size: 42rpx;
  line-height: 1;
}

.guest-form {
  display: grid;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.form-input {
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid rgba(127, 67, 24, 0.14);
  box-sizing: border-box;
  font-size: 26rpx;
}

.form-submit {
  height: 82rpx;
}

.guest-item,
.coupon-item,
.service-card {
  margin-bottom: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid rgba(127, 67, 24, 0.1);
}

.guest-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.guest-name {
  font-size: 29rpx;
  font-weight: 700;
}

.guest-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7c6651;
}

.guest-actions {
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 18rpx;
}

.guest-action {
  min-width: 92rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(185, 107, 44, 0.1);
  color: #7f4318;
  font-size: 23rpx;
}

.guest-action.danger {
  color: #b44a3b;
  background: rgba(180, 74, 59, 0.1);
}

.panel-empty {
  padding: 28rpx 0;
  text-align: center;
  color: #7c6651;
  font-size: 24rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.coupon-value {
  width: 114rpx;
  min-height: 112rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, #bc7335, #7f4318);
  color: #fff8ef;
  font-size: 31rpx;
  font-weight: 700;
}

.coupon-main {
  flex: 1;
  min-width: 0;
}

.coupon-title {
  font-size: 28rpx;
  font-weight: 700;
}

.coupon-desc,
.coupon-date {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7c6651;
}

.coupon-action {
  width: 100rpx;
  height: 54rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(185, 107, 44, 0.12);
  color: #7f4318;
  font-size: 22rpx;
  font-weight: 700;
}

.coupon-action-disabled {
  color: #7c6651;
  background: rgba(124, 102, 81, 0.12);
}

.password-card,
.checkout-item {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(127, 67, 24, 0.1);
}

.password-card {
  text-align: center;
  background: linear-gradient(180deg, #fffaf1 0%, #fff 100%);
}

.password-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 0;
  color: #7c6651;
  font-size: 24rpx;
  border-bottom: 1rpx solid rgba(127, 67, 24, 0.08);
}

.password-meta text:last-child {
  max-width: 430rpx;
  color: #352416;
  font-weight: 700;
  text-align: right;
}

.password-room {
  margin-top: 26rpx;
  color: #7f4318;
  font-size: 30rpx;
  font-weight: 700;
}

.password-code {
  margin-top: 16rpx;
  font-size: 72rpx;
  line-height: 1.1;
  font-weight: 800;
  letter-spacing: 8rpx;
  color: #2f251b;
}

.password-expire {
  margin-top: 14rpx;
  color: #9b5b28;
  font-size: 24rpx;
}

.checkout-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.checkout-title {
  font-size: 28rpx;
  font-weight: 700;
}

.checkout-line {
  margin-top: 8rpx;
  color: #7c6651;
  font-size: 22rpx;
}

.checkout-btn {
  width: 110rpx;
  height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff8ef;
  background: linear-gradient(135deg, #bc7335, #7f4318);
  font-size: 23rpx;
  font-weight: 700;
}

.service-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(127, 67, 24, 0.08);
}

.service-row:last-child {
  border-bottom: 0;
}

.service-label {
  color: #7c6651;
  font-size: 24rpx;
}

.service-value {
  max-width: 430rpx;
  text-align: right;
  color: #352416;
  font-size: 26rpx;
  font-weight: 700;
  word-break: break-all;
}

.service-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.service-btn,
.native-contact {
  height: 82rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.native-contact {
  width: 100%;
  margin: 18rpx 0 0;
  padding: 0;
  border: 1rpx solid rgba(127, 67, 24, 0.14);
  line-height: 82rpx;
}

.native-contact::after {
  border: 0;
}
