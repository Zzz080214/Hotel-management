.hero {
  position: relative;
  padding: 44rpx 32rpx 36rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 88% 8%, rgba(216, 184, 136, 0.20), transparent 42%),
    linear-gradient(155deg, #0d1822 0%, #142434 56%, #1d3146 100%);
}

.hero::after {
  content: "";
  position: absolute;
  left: 32rpx;
  top: 36rpx;
  width: 96rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(216, 184, 136, 0.95), transparent);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  padding: 0 20rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: rgba(216, 184, 136, 0.14);
  border: 1rpx solid rgba(216, 184, 136, 0.30);
  color: #d8b888;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 60rpx;
  font-weight: 500;
  color: #f5e8cc;
  letter-spacing: 8rpx;
  font-family: "Songti SC", "STSong", "Source Han Serif", serif;
}

.hero-subtitle {
  margin-top: 16rpx;
  max-width: 560rpx;
  font-size: 24rpx;
  line-height: 1.85;
  color: rgba(231, 234, 238, 0.74);
  letter-spacing: 0.6rpx;
}

.source-line {
  margin-top: 14rpx;
  font-size: 20rpx;
  color: rgba(216, 184, 136, 0.72);
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 36rpx;
}

.action-btn {
  flex: 1;
}

.hero .primary-btn {
  color: #14202c;
  background: linear-gradient(135deg, #e8cda0 0%, #b8945c 100%);
  box-shadow: 0 14rpx 28rpx rgba(120, 90, 50, 0.36);
  border: 0;
}

.hero .ghost-btn {
  color: #f3e8cf;
  background: rgba(255, 252, 247, 0.06);
  border: 1rpx solid rgba(216, 184, 136, 0.32);
}

.hero-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 36rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(216, 184, 136, 0.14);
}

.hero-stat {
  flex: 1;
  padding: 4rpx 0;
  text-align: left;
}

.hero-stat-value {
  font-size: 38rpx;
  font-weight: 600;
  color: #f5e8cc;
  letter-spacing: 0;
  font-variant-numeric: tabular-nums;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(216, 184, 136, 0.72);
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}

.section {
  margin-top: 36rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-item {
  position: relative;
  padding: 28rpx 24rpx;
  overflow: hidden;
  transition: transform 0.25s ease;
}

.quick-item::before {
  content: "";
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 48rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #c8a570, transparent);
}

.quick-item:active {
  transform: translateY(2rpx);
}

.quick-title {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
}

.quick-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #7a8290;
}

.more-link {
  font-size: 22rpx;
  font-weight: 600;
  color: #8a6a3e;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.room-card {
  overflow: hidden;
  margin-bottom: 22rpx;
  transition: transform 0.25s ease;
}

.room-card:active {
  transform: translateY(2rpx);
}

.room-image {
  width: 100%;
  height: 320rpx;
  display: block;
}

.room-body {
  padding: 28rpx 26rpx 26rpx;
}

.room-top,
.notice-top,
.room-bottom {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
}

.room-meta,
.notice-content,
.room-summary {
  margin-top: 10rpx;
  color: #7a8290;
  font-size: 23rpx;
  line-height: 1.75;
  letter-spacing: 0.4rpx;
}

.feature-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.feature-tag {
  padding: 0 18rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #8a6a3e;
  background: rgba(184, 148, 92, 0.08);
  border: 1rpx solid rgba(184, 148, 92, 0.18);
  letter-spacing: 0.4rpx;
}

.room-bottom {
  align-items: flex-end;
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(28, 38, 50, 0.06);
}

.price-wrap {
  display: flex;
  align-items: baseline;
  color: #14202c;
}

.price-symbol {
  font-size: 22rpx;
  font-weight: 600;
  color: #8a6a3e;
}

.price-num {
  margin-left: 4rpx;
  font-size: 46rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0;
  font-variant-numeric: tabular-nums;
}

.price-note {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: #7a8290;
}

.book-now {
  padding: 0 28rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1d3146, #0f1d2a);
  color: #f4e8d2;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(216, 184, 136, 0.18);
}

.notice-card {
  padding: 28rpx 26rpx;
  margin-bottom: 18rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
}
