.hero {
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(233, 193, 145, 0.35), transparent 34%),
    linear-gradient(135deg, rgba(255, 250, 241, 0.96), rgba(245, 228, 203, 0.94));
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(185, 107, 44, 0.12);
  color: #7f4318;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 52rpx;
  font-weight: 700;
  color: #352416;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7c6651;
}

.source-line {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9b5b28;
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.action-btn {
  flex: 1;
}

.hero-stats {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.hero-stat {
  flex: 1;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 249, 240, 0.72);
}

.hero-stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #7f4318;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7c6651;
}

.section {
  margin-top: 28rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.quick-item {
  padding: 24rpx;
}

.quick-title {
  font-size: 28rpx;
  font-weight: 700;
}

.quick-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7c6651;
}

.more-link {
  font-size: 24rpx;
  font-weight: 700;
  color: #9b5b28;
}

.room-card {
  overflow: hidden;
  margin-bottom: 20rpx;
}

.room-image {
  width: 100%;
  height: 256rpx;
  display: block;
}

.room-body {
  padding: 24rpx;
}

.room-top,
.notice-top,
.room-bottom {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 700;
}

.room-meta,
.notice-content,
.room-summary {
  margin-top: 10rpx;
  color: #7c6651;
  font-size: 24rpx;
  line-height: 1.7;
}

.feature-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.feature-tag {
  padding: 0 16rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #7f4318;
  background: rgba(185, 107, 44, 0.08);
}

.room-bottom {
  align-items: flex-end;
  margin-top: 20rpx;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  color: #9b5b28;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 700;
}

.price-num {
  font-size: 42rpx;
  font-weight: 700;
}

.price-note {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: #7c6651;
}

.book-now {
  padding: 0 24rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #bc7335, #7f4318);
  color: #fff8ef;
  font-size: 24rpx;
  font-weight: 700;
}

.notice-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
}
