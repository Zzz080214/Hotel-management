.face-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.camera-card {
  position: relative;
  height: 760rpx;
  border-radius: 26rpx;
  overflow: hidden;
  background: #0a131c;
  box-shadow: 0 22rpx 50rpx rgba(15, 29, 42, 0.32);
  border: 1rpx solid rgba(216, 184, 136, 0.16);
}

.camera-view {
  width: 100%;
  height: 100%;
}

.camera-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(8, 14, 22, 0.18), rgba(8, 14, 22, 0.46));
}

.face-frame {
  position: absolute;
  left: 50%;
  top: 48%;
  width: 430rpx;
  height: 520rpx;
  transform: translate(-50%, -50%);
  border: 3rpx solid rgba(216, 184, 136, 0.78);
  border-radius: 52% 52% 46% 46%;
  box-sizing: border-box;
  overflow: hidden;
}

.face-frame-active {
  border-color: #63d894;
  box-shadow: 0 0 32rpx rgba(99, 216, 148, 0.42);
}

.scan-line {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #d8b888;
  box-shadow: 0 0 24rpx rgba(216, 184, 136, 0.92);
  animation: scanMove 1.8s linear infinite;
}

@keyframes scanMove {
  0% { top: 42rpx; opacity: 0.25; }
  12% { opacity: 1; }
  88% { opacity: 1; }
  100% { top: 456rpx; opacity: 0.25; }
}

.corner {
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  border-color: rgba(216, 184, 136, 0.92);
  border-style: solid;
}

.corner-lt { left: 24rpx; top: 24rpx; border-width: 4rpx 0 0 4rpx; }
.corner-rt { right: 24rpx; top: 24rpx; border-width: 4rpx 4rpx 0 0; }
.corner-lb { left: 24rpx; bottom: 24rpx; border-width: 0 0 4rpx 4rpx; }
.corner-rb { right: 24rpx; bottom: 24rpx; border-width: 0 4rpx 4rpx 0; }

.detect-badge {
  position: absolute;
  left: 50%;
  bottom: 38rpx;
  transform: translateX(-50%);
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f4e8d2;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1.6rpx;
  background: rgba(15, 29, 42, 0.78);
  border: 1rpx solid rgba(216, 184, 136, 0.30);
}

.detect-badge-ok {
  background: rgba(47, 125, 85, 0.86);
  border-color: rgba(99, 216, 148, 0.32);
}

.status-card {
  margin-top: 24rpx;
  padding: 32rpx 30rpx;
}

.status-line {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0.6rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #b8945c;
  box-shadow: 0 0 12rpx rgba(184, 148, 92, 0.4);
}

.status-dot.scanning,
.status-dot.comparing {
  background: #b07a2c;
  box-shadow: 0 0 12rpx rgba(176, 122, 44, 0.4);
}

.status-dot.success {
  background: #2f7d55;
  box-shadow: 0 0 12rpx rgba(47, 125, 85, 0.4);
}

.status-dot.failed {
  background: #a05a56;
  box-shadow: 0 0 12rpx rgba(160, 90, 86, 0.4);
}

.loading-row {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #7a8290;
  font-size: 23rpx;
  letter-spacing: 0.4rpx;
}

.loading-ring {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(28, 38, 50, 0.10);
  border-top-color: #b8945c;
  border-radius: 50%;
  animation: spin 0.85s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.success-box,
.fail-box {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 16rpx;
  border: 1rpx solid;
}

.success-box {
  background: rgba(47, 125, 85, 0.08);
  border-color: rgba(47, 125, 85, 0.20);
}

.fail-box {
  background: rgba(160, 90, 86, 0.08);
  border-color: rgba(160, 90, 86, 0.20);
}

.success-title,
.fail-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
}

.success-room {
  margin-top: 18rpx;
  font-size: 64rpx;
  font-weight: 600;
  color: #2f7d55;
  letter-spacing: 4rpx;
  font-variant-numeric: tabular-nums;
}

.success-note,
.fail-note {
  margin-top: 12rpx;
  color: #7a8290;
  font-size: 23rpx;
  line-height: 1.7;
  letter-spacing: 0.4rpx;
}

.action-row {
  margin-top: 28rpx;
}

.action-btn {
  width: 100%;
}

.success-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
