.header {
  padding: 32rpx 30rpx;
}

.source-line {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #8a6a3e;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
}

.tab-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.tab-pill {
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #14202c;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(28, 38, 50, 0.10);
  letter-spacing: 1rpx;
}

.tab-pill-active {
  color: #f4e8d2;
  background: linear-gradient(135deg, #1d3146, #0f1d2a);
  border-color: transparent;
  box-shadow: 0 8rpx 18rpx rgba(15, 29, 42, 0.22);
}

.order-card {
  padding: 28rpx 26rpx;
  margin-top: 22rpx;
}

.order-top,
.order-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.order-id {
  font-size: 28rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0.4rpx;
  font-variant-numeric: tabular-nums;
}

.order-room {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7a8290;
  letter-spacing: 0.4rpx;
}

.order-row {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(28, 38, 50, 0.06);
  font-size: 23rpx;
  color: #14202c;
}

.order-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.face-btn,
.cancel-order-btn {
  height: 64rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 600;
  letter-spacing: 1.6rpx;
}

.face-btn {
  color: #14202c;
  background: linear-gradient(135deg, #e8cda0, #b8945c);
  box-shadow: 0 12rpx 22rpx rgba(120, 90, 50, 0.24);
}

.cancel-order-btn {
  color: #a05a56;
  background: rgba(160, 90, 86, 0.08);
  border: 1rpx solid rgba(160, 90, 86, 0.22);
}

.is-disabled {
  opacity: 0.55;
}

.empty-card {
  margin-top: 22rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  color: #7a8290;
  font-size: 24rpx;
  letter-spacing: 0.6rpx;
}
