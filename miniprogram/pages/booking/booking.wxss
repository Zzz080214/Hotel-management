.summary-card {
  overflow: hidden;
}

.summary-image {
  width: 100%;
  height: 280rpx;
}

.summary-body,
.form-card,
.total-card {
  padding: 24rpx;
}

.summary-top,
.info-row,
.total-card {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.summary-name {
  font-size: 34rpx;
  font-weight: 700;
}

.summary-meta,
.summary-text,
.total-note {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7c6651;
}

.form-card,
.total-card {
  margin-top: 20rpx;
}

.source-line {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9b5b28;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7c6651;
}

.field-input {
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fffefb;
  border: 1rpx solid rgba(127, 67, 24, 0.12);
}

.info-box {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(185, 107, 44, 0.08);
}

.info-row {
  font-size: 24rpx;
  line-height: 1.8;
}

.total-label {
  font-size: 24rpx;
  color: #7c6651;
}

.total-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #9b5b28;
}

.submit-btn {
  margin-top: 24rpx;
}
