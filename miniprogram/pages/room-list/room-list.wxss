.header {
  padding: 32rpx 30rpx;
}

.source-line {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #8a6a3e;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
}

.tab-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.tab-pill {
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #14202c;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(28, 38, 50, 0.10);
  letter-spacing: 1rpx;
}

.tab-pill-active {
  color: #f4e8d2;
  background: linear-gradient(135deg, #1d3146, #0f1d2a);
  border-color: transparent;
  box-shadow: 0 8rpx 18rpx rgba(15, 29, 42, 0.22);
}

.room-card {
  overflow: hidden;
  margin-top: 22rpx;
  transition: transform 0.25s ease;
}

.room-card:active {
  transform: translateY(2rpx);
}

.room-image {
  width: 100%;
  height: 320rpx;
}

.room-content {
  padding: 28rpx 26rpx;
}

.room-top,
.bottom-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
}

.room-meta,
.room-summary {
  margin-top: 12rpx;
  color: #7a8290;
  font-size: 23rpx;
  line-height: 1.75;
  letter-spacing: 0.4rpx;
}

.feature-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.feature-tag {
  padding: 0 18rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 999rpx;
  background: rgba(184, 148, 92, 0.08);
  color: #8a6a3e;
  font-size: 21rpx;
  border: 1rpx solid rgba(184, 148, 92, 0.18);
  letter-spacing: 0.4rpx;
}

.bottom-row {
  align-items: center;
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(28, 38, 50, 0.06);
}

.price-symbol {
  font-size: 22rpx;
  font-weight: 600;
  color: #8a6a3e;
}

.price-num {
  margin-left: 4rpx;
  font-size: 46rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 0;
  font-variant-numeric: tabular-nums;
}

.price-note {
  font-size: 22rpx;
  color: #7a8290;
}

.reserve-btn {
  min-width: 140rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #f4e8d2;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  background: linear-gradient(135deg, #1d3146, #0f1d2a);
  border: 1rpx solid rgba(216, 184, 136, 0.18);
}
