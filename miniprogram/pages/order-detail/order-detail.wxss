.hero-card {
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 320rpx;
}

.hero-body,
.detail-card {
  padding: 28rpx;
}

.hero-top,
.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #14202c;
  letter-spacing: 1rpx;
}

.hero-subtitle,
.hero-meta,
.room-meta,
.room-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #7a8290;
  letter-spacing: 0.4rpx;
}

.source-line {
  margin-top: 14rpx;
  font-size: 20rpx;
  color: #8a6a3e;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
}

.detail-card,
.action-row {
  margin-top: 22rpx;
}

.detail-list {
  margin-top: 20rpx;
}

.detail-row {
  padding: 18rpx 0;
  font-size: 24rpx;
  color: #14202c;
  border-bottom: 1rpx solid rgba(28, 38, 50, 0.06);
}

.detail-row:last-child {
  border-bottom: 0;
}

.feature-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.feature-pill {
  height: 46rpx;
  padding: 0 20rpx;
  line-height: 46rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #8a6a3e;
  background: rgba(184, 148, 92, 0.08);
  border: 1rpx solid rgba(184, 148, 92, 0.18);
  letter-spacing: 0.4rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-row > view {
  flex: 1;
}

.cancel-btn {
  color: #a05a56;
  background: rgba(160, 90, 86, 0.08);
  border: 1rpx solid rgba(160, 90, 86, 0.20);
}

.retry-btn {
  margin-top: 22rpx;
}
